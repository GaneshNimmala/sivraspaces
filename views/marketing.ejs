    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            try {
                // Fetch the catalogs
                const response = await fetch('/admin/catalogs/read');
                if (!response.ok) throw new Error("Failed to fetch catalogs");
                const catalogs = await response.json();
                console.log('catalogs', catalogs);

                // Iterate over each catalog and render the PDF
                catalogs.forEach((catalog, index) => {
                    renderPDF(catalog.pdfPath, catalog.title, index);
                });
            } catch (error) {
                console.error("Error fetching catalogs:", error);
            }
        });

        // Function to render the top half of the PDF
        async function renderPDF(pdfPath, title, index) {
            const containerHeight = 500; // Max container height
            const pdfContainer = document.getElementById('pdf-container');

            try {
                const pdf = await pdfjsLib.getDocument(pdfPath).promise;
                const page = await pdf.getPage(1);
                const viewport = page.getViewport({ scale: 1 });

                // Calculate the scale for half-page rendering
                const halfPageScale = containerHeight / (viewport.height / 2);
                const scaledViewport = page.getViewport({ scale: halfPageScale });

                // Create a canvas for the PDF
                const canvas = document.createElement('canvas');
                canvas.id = `pdf-canvas-${index}`;
                canvas.className = 'pdf-canvas';
                const context = canvas.getContext('2d');
                canvas.width = scaledViewport.width;
                canvas.height = scaledViewport.height;

                // Render the PDF on the canvas
                const renderContext = {
                    canvasContext: context,
                    viewport: scaledViewport
                };
                await page.render(renderContext);

                // Create a title for the canvas
                const canvasTitle = document.createElement('div');
                canvasTitle.className = 'pdf-title';
                canvasTitle.innerText = title;

                // Create an anchor tag that wraps the PDF canvas and title
                const aTag = document.createElement('a');
                aTag.setAttribute("href", `${window.location.origin}${pdfPath}`);
                aTag.setAttribute("target", "_blank");
                aTag.style.textDecoration = "none"; // Optional: remove underline

                // Wrap canvas and title inside a container
                const canvasWrapper = document.createElement('div');
                canvasWrapper.className = 'pdf-wrapper';
                canvasWrapper.appendChild(canvas);
                canvasWrapper.appendChild(canvasTitle);

                // Append the wrapper to the anchor tag
                aTag.appendChild(canvasWrapper);

                // Append the anchor tag to the container
                const column = document.createElement('div').setAttribute("class", "col-12 col-md-6 col-lg-4 mt-3");
                column.appendChild(aTag);
                pdfContainer.appendChild(column);
            } catch (error) {
                console.error('Error rendering PDF:', error, pdfPath);
            }
        }
    </script>

