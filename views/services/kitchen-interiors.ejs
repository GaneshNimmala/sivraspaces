  <link rel="canonical" href="https://sivraspaces.com/services/kitchen-interiors">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://sivraspaces.com/services/kitchen-interiors">
  <meta property="og:title" content="Kitchen Interiors in Hyderabad - Sivra Spaces">
  <meta property="og:description" content="Custom modular kitchen interiors in Hyderabad by Sivra Spaces. Functional layouts, premium finishes, and expert installation for your dream kitchen.">
  <meta property="og:image" content="https://sivraspaces.com/assets/img/services/3x/service1.jpg">
  <meta property="og:site_name" content="Sivra Spaces">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Kitchen Interiors in Hyderabad - Sivra Spaces">
  <meta name="twitter:description" content="Custom modular kitchen interiors in Hyderabad by Sivra Spaces. Functional layouts, premium finishes, and expert installation for your dream kitchen.">
  <meta name="twitter:image" content="https://sivraspaces.com/assets/img/services/3x/service1.jpg">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/favicon_io/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon_io/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/favicon_io/favicon-16x16.png">
  <link rel="manifest" href="/assets/img/favicon_io/site.webmanifest">
  <link href="/assets/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/bootstrap-icons/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/assets/css/common.css">
  <link rel="stylesheet" href="/assets/sweetalert/sweetalert2.css">
</head>
<body>
  <div class="about-outer-wrapper">
    <div class="header-wrapper">
      <div class="header-contactdetails-wrapper">
        <div class="header-contactdetails-textbox">
          <span>Call Now: +91 91331 32333 | Email: sivraspaces.interiors@gmail.com</span>
          <span>Opening time: Sun-Sat 9:00 AM - 7:00 PM</span>
        </div>
      </div>
      <div class="header-navigation-wrapper">
        <div><%- include('../partials/header') %></div>
      </div>
    </div>

    <div class="body-wrapper">
      <main>
        <!-- Breadcrumb -->
        <section id="breadcrumb" class="breadcrumb-section">
          <div class="breadcrumb-wrapper">
            <img src="/assets/img/breadcrumb/services.png" alt="services breadcrumb">
            <div class="breadcrumb-overlay"></div>
            <div class="breadcrumb-text">
              <h2><span style="color: #f45b1e">KITCHEN INTERIORS</span></h2>
              <p>Modular & Custom Kitchen Design Solutions</p>
              <div class="breadcrumb-path">
                <span style="color: black">HOME</span>
                <i class="bi bi-dot"></i>
                <a href="/services/interior-design" style="color: black; text-decoration: none;">SERVICES</a>
                <i class="bi bi-dot"></i>
                <span>KITCHEN INTERIORS</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Hero Section -->
        <section class="py-5">
          <div class="container">
            <div class="row align-items-center gy-4">
              <div class="col-md-6">
                <h2 class="fw-bold">
                  <span class="text-uppercase">Kitchen Interiors</span><br>
                  <span class="highlight-word text-uppercase">Designed for Your Lifestyle</span>
                </h2>
                <p class="mt-3">
                  At Sivra Spaces, we design modular and custom kitchens that perfectly blend style with functionality. Every kitchen is tailored to your space, your habits, and your aesthetic — optimizing every inch with quality materials and smart storage solutions.
                </p>
                <p>
                  From sleek contemporary finishes to warm traditional tones, we bring your dream kitchen to life with precision craftsmanship and durable materials built to last for years.
                </p>
              </div>
              <div class="col-md-6 text-center">
                <!-- Placeholder image — replace with actual kitchen image -->
                <img src="/assets/img/services/3x/service1.jpg" alt="Kitchen Interiors" class="img-fluid rounded" style="height: 350px; width: 100%; object-fit: cover;">
              </div>
            </div>
          </div>
        </section>

        <!-- Features Section -->
        <section style="background-color: #132023;" class="py-5">
          <div class="container">
            <div class="text-center mb-5">
              <h2 class="fw-bold text-light">WHAT WE <span class="highlight-word">OFFER</span></h2>
              <p class="text-light">Everything you need for a perfect kitchen, under one roof.</p>
            </div>
            <div class="row gy-4">
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-grid-3x3-gap-fill" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Modular Design</h5>
                  <p class="text-light" style="opacity: 0.8;">Pre-engineered modular units that fit perfectly and can be customized to your exact requirements.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-box-seam" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Smart Storage</h5>
                  <p class="text-light" style="opacity: 0.8;">Pull-out drawers, corner carousels, and overhead units designed to maximize every inch of space.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-stars" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Premium Materials</h5>
                  <p class="text-light" style="opacity: 0.8;">Marine-grade ply, moisture-resistant boards, and high-quality laminates for long-lasting durability.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-brush" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Custom Finishes</h5>
                  <p class="text-light" style="opacity: 0.8;">Wide range of finishes — matte, gloss, textured, or wood grain — to match your home's style.</p>
                </div>
              </div>
            </div>
          </div>
        </section>


        <!-- Footer -->
        <section id="footer" class="footer-wrapper">
          <%- include('../partials/footer') %>
        </section>

        <section id="get-a-quote-sticker" class="get-a-quote-sticker-wrap d-flex flex-column">
          <%- include('../partials/get-quote-sticker') %>
        </section>

        <section>
          <div class="overlay" id="overlay"></div>
          <div id="get-a-quote-dialog" class="get-a-quote-dialog">
            <div style="text-align: right" id="cancel-quote-form">
              <i class="bi bi-x-circle-fill" style="font-size: 40px"></i>
            </div>
            <div><%- include('../partials/get-quote-form') %></div>
          </div>
        </section>
      </main>

      <%- include('../partials/mobile-nav') %>
    </div>
  </div>

  <script src="/assets/JQuery/jquery1.min.js"></script>
  <script src="/assets/JS/mobile-navigation-script.js"></script>
  <script src="/assets/sweetalert/sweetalert2.all.min.js"></script>
  <script src="/assets/JS/get-a-quote-dialog-script.js"></script>
  <script src="/assets/JS/contact-form-submission.js"></script>
</body>
</html>
