  <meta property="og:title" content="Pooja Unit Design in Hyderabad - Sivra Spaces">
  <meta property="og:description" content="Beautifully crafted pooja units with traditional aesthetics and modern woodworking by Sivra Spaces, Hyderabad.">
  <meta property="og:image" content="https://sivraspaces.com/assets/img/services/3x/service5.jpg">
  <meta property="og:site_name" content="Sivra Spaces">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Pooja Unit Design in Hyderabad - Sivra Spaces">
  <meta name="twitter:description" content="Beautifully crafted pooja units with traditional aesthetics and modern woodworking by Sivra Spaces, Hyderabad.">
  <meta name="twitter:image" content="https://sivraspaces.com/assets/img/services/3x/service5.jpg">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/favicon_io/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon_io/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/favicon_io/favicon-16x16.png">
  <link rel="manifest" href="/assets/img/favicon_io/site.webmanifest">
  <link href="/assets/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/bootstrap-icons/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/assets/css/common.css">
  <link rel="stylesheet" href="/assets/sweetalert/sweetalert2.css">
</head>
<body>
  <div class="about-outer-wrapper">
    <div class="header-wrapper">
      <div class="header-contactdetails-wrapper">
        <div class="header-contactdetails-textbox">
          <span>Call Now: +91 91331 32333 | Email: sivraspaces.interiors@gmail.com</span>
          <span>Opening time: Sun-Sat 9:00 AM - 7:00 PM</span>
        </div>
      </div>
      <div class="header-navigation-wrapper">
        <div><%- include('../partials/header') %></div>
      </div>
    </div>

    <div class="body-wrapper">
      <main>
        <!-- Breadcrumb -->
        <section id="breadcrumb" class="breadcrumb-section">
          <div class="breadcrumb-wrapper">
            <img src="/assets/img/breadcrumb/services.png" alt="services breadcrumb">
            <div class="breadcrumb-overlay"></div>
            <div class="breadcrumb-text">
              <h2><span style="color: #f45b1e">POOJA UNIT</span></h2>
              <p>Sacred Spaces Crafted with Devotion & Elegance</p>
              <div class="breadcrumb-path">
                <span style="color: black">HOME</span>
                <i class="bi bi-dot"></i>
                <a href="/services/interior-design" style="color: black; text-decoration: none;">SERVICES</a>
                <i class="bi bi-dot"></i>
                <span>POOJA UNIT</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Hero Section -->
        <section class="py-5">
          <div class="container">
            <div class="row align-items-center gy-4">
              <div class="col-md-6">
                <h2 class="fw-bold">
                  <span class="text-uppercase">Pooja Units</span><br>
                  <span class="highlight-word text-uppercase">A Sacred Corner in Your Home</span>
                </h2>
                <p class="mt-3">
                  At Sivra Spaces, we craft pooja units that bring a sense of devotion and elegance to your home. Each unit is designed with traditional aesthetics and modern woodworking craftsmanship, creating a serene and beautiful worship space for your family.
                </p>
                <p>
                  From compact wall-mounted units to grand floor-standing mandirs, we customize every detail — carvings, finishes, shelving, and lighting — to reflect your spiritual values and home style.
                </p>
              </div>
              <div class="col-md-6 text-center">
                <img src="/assets/img/services/3x/service5.jpg" alt="Pooja Unit" class="img-fluid rounded" style="height: 350px; width: 100%; object-fit: cover;">
              </div>
            </div>
          </div>
        </section>

        <!-- Features Section -->
        <section style="background-color: #132023;" class="py-5">
          <div class="container">
            <div class="text-center mb-5">
              <h2 class="fw-bold text-light">WHAT WE <span class="highlight-word">OFFER</span></h2>
              <p class="text-light">Pooja units that honour tradition with impeccable craft.</p>
            </div>
            <div class="row gy-4">
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-house-heart" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Traditional Design</h5>
                  <p class="text-light" style="opacity: 0.8;">Classic mandir-style designs with arches, pillars, and intricate carvings rooted in tradition.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-stars" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Premium Wood</h5>
                  <p class="text-light" style="opacity: 0.8;">Crafted from teak, sheesham, or MDF with premium finishes to stand the test of time.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-rulers" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Custom Sizes</h5>
                  <p class="text-light" style="opacity: 0.8;">Built to fit your space — from compact wall units to large dedicated prayer rooms.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-lightbulb" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Integrated Lighting</h5>
                  <p class="text-light" style="opacity: 0.8;">Warm LED lighting options to create a divine, serene ambiance in your prayer space.</p>
                </div>
              </div>
            </div>
          </div>
        </section>


        <!-- Footer -->
        <section id="footer" class="footer-wrapper">
          <%- include('../partials/footer') %>
        </section>

        <section id="get-a-quote-sticker" class="get-a-quote-sticker-wrap d-flex flex-column">
          <%- include('../partials/get-quote-sticker') %>
        </section>

        <section>
          <div class="overlay" id="overlay"></div>
          <div id="get-a-quote-dialog" class="get-a-quote-dialog">
            <div style="text-align: right" id="cancel-quote-form">
              <i class="bi bi-x-circle-fill" style="font-size: 40px"></i>
            </div>
            <div><%- include('../partials/get-quote-form') %></div>
          </div>
        </section>
      </main>

      <%- include('../partials/mobile-nav') %>
    </div>
  </div>

  <script src="/assets/JQuery/jquery1.min.js"></script>
  <script src="/assets/JS/mobile-navigation-script.js"></script>
  <script src="/assets/sweetalert/sweetalert2.all.min.js"></script>
  <script src="/assets/JS/get-a-quote-dialog-script.js"></script>
  <script src="/assets/JS/contact-form-submission.js"></script>
</body>
</html>
