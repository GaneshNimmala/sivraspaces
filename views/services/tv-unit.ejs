<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Stylish and functional TV units designed for your living room by Sivra Spaces, Hyderabad.">
  <title>TV Unit Design in Hyderabad - Sivra Spaces</title>
  <link rel="canonical" href="https://sivraspaces.com/services/tv-unit">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://sivraspaces.com/services/tv-unit">
  <meta property="og:title" content="TV Unit Design in Hyderabad - Sivra Spaces">
  <meta property="og:description" content="Stylish and functional TV units for your living room by Sivra Spaces, Hyderabad. Wall-mounted and floor-standing with LED backlighting.">
  <meta property="og:image" content="https://sivraspaces.com/assets/img/services/3x/service3.jpg">
  <meta property="og:site_name" content="Sivra Spaces">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="TV Unit Design in Hyderabad - Sivra Spaces">
  <meta name="twitter:description" content="Stylish and functional TV units for your living room by Sivra Spaces, Hyderabad. Wall-mounted and floor-standing with LED backlighting.">
  <meta name="twitter:image" content="https://sivraspaces.com/assets/img/services/3x/service3.jpg">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/favicon_io/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon_io/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/favicon_io/favicon-16x16.png">
  <link rel="manifest" href="/assets/img/favicon_io/site.webmanifest">
  <link href="/assets/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/bootstrap-icons/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/assets/css/common.css">
  <link rel="stylesheet" href="/assets/sweetalert/sweetalert2.css">
</head>
<body>
  <div class="about-outer-wrapper">
    <div class="header-wrapper">
      <div class="header-contactdetails-wrapper">
        <div class="header-contactdetails-textbox">
          <span>Call Now: +91 91331 32333 | Email: sivraspaces.interiors@gmail.com</span>
          <span>Opening time: Sun-Sat 9:00 AM - 7:00 PM</span>
        </div>
      </div>
      <div class="header-navigation-wrapper">
        <div><%- include('../partials/header') %></div>
      </div>
    </div>

    <div class="body-wrapper">
      <main>
        <!-- Breadcrumb -->
        <section id="breadcrumb" class="breadcrumb-section">
          <div class="breadcrumb-wrapper">
            <img src="/assets/img/breadcrumb/services.png" alt="services breadcrumb">
            <div class="breadcrumb-overlay"></div>
            <div class="breadcrumb-text">
              <h2><span style="color: #f45b1e">TV UNIT</span></h2>
              <p>Stylish TV Units That Define Your Living Room</p>
              <div class="breadcrumb-path">
                <span style="color: black">HOME</span>
                <i class="bi bi-dot"></i>
                <a href="/services/interior-design" style="color: black; text-decoration: none;">SERVICES</a>
                <i class="bi bi-dot"></i>
                <span>TV UNIT</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Hero Section -->
        <section class="py-5">
          <div class="container">
            <div class="row align-items-center gy-4">
              <div class="col-md-6">
                <h2 class="fw-bold">
                  <span class="text-uppercase">TV Units</span><br>
                  <span class="highlight-word text-uppercase">The Focal Point of Your Living Room</span>
                </h2>
                <p class="mt-3">
                  A well-designed TV unit does more than hold a screen — it anchors the entire living space. At Sivra Spaces, we craft TV units that are both a design statement and a practical storage solution, with smart cable management and display shelving tailored to your room.
                </p>
                <p>
                  From wall-mounted floating units to floor-standing entertainment centers, we design and build to your exact specifications with premium finishes.
                </p>
              </div>
              <div class="col-md-6 text-center">
                <img src="/assets/img/services/3x/service3.jpg" alt="TV Unit" class="img-fluid rounded" style="height: 350px; width: 100%; object-fit: cover;">
              </div>
            </div>
          </div>
        </section>

        <!-- Features Section -->
        <section style="background-color: #132023;" class="py-5">
          <div class="container">
            <div class="text-center mb-5">
              <h2 class="fw-bold text-light">WHAT WE <span class="highlight-word">OFFER</span></h2>
              <p class="text-light">TV units designed for style, function, and longevity.</p>
            </div>
            <div class="row gy-4">
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-tv" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Wall-Mounted Units</h5>
                  <p class="text-light" style="opacity: 0.8;">Sleek floating TV units that give your living room a modern, spacious feel.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-layout-wtf" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Cable Management</h5>
                  <p class="text-light" style="opacity: 0.8;">Built-in cable channels to keep wires hidden and your space neat and tidy.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-collection" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Display Shelving</h5>
                  <p class="text-light" style="opacity: 0.8;">Open shelves and closed cabinets for display items, gadgets, and media storage.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-lightbulb" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">LED Backlighting</h5>
                  <p class="text-light" style="opacity: 0.8;">Optional LED strip lighting behind units for a premium, cinematic ambiance.</p>
                </div>
              </div>
            </div>
          </div>
        </section>


        <!-- Footer -->
        <section id="footer" class="footer-wrapper">
          <%- include('../partials/footer') %>
        </section>

        <section id="get-a-quote-sticker" class="get-a-quote-sticker-wrap d-flex flex-column">
          <%- include('../partials/get-quote-sticker') %>
        </section>

        <section>
          <div class="overlay" id="overlay"></div>
          <div id="get-a-quote-dialog" class="get-a-quote-dialog">
            <div style="text-align: right" id="cancel-quote-form">
              <i class="bi bi-x-circle-fill" style="font-size: 40px"></i>
            </div>
            <div><%- include('../partials/get-quote-form') %></div>
          </div>
        </section>
      </main>

      <%- include('../partials/mobile-nav') %>
    </div>
  </div>

  <script src="/assets/JQuery/jquery1.min.js"></script>
  <script src="/assets/JS/mobile-navigation-script.js"></script>
  <script src="/assets/sweetalert/sweetalert2.all.min.js"></script>
  <script src="/assets/JS/get-a-quote-dialog-script.js"></script>
  <script src="/assets/JS/contact-form-submission.js"></script>
</body>
</html>
