<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Custom wardrobes in Hyderabad — sliding, hinged, and walk-in configurations by Sivra Spaces.">
  <title>Wardrobe Design in Hyderabad - Sivra Spaces</title>
  <link rel="canonical" href="https://sivraspaces.com/services/wardrobe">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://sivraspaces.com/services/wardrobe">
  <meta property="og:title" content="Wardrobe Design in Hyderabad - Sivra Spaces">
  <meta property="og:description" content="Custom wardrobes in Hyderabad — sliding, hinged, and walk-in configurations with premium finishes by Sivra Spaces.">
  <meta property="og:image" content="https://sivraspaces.com/assets/img/services/3x/service2.jpg">
  <meta property="og:site_name" content="Sivra Spaces">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Wardrobe Design in Hyderabad - Sivra Spaces">
  <meta name="twitter:description" content="Custom wardrobes in Hyderabad — sliding, hinged, and walk-in configurations with premium finishes by Sivra Spaces.">
  <meta name="twitter:image" content="https://sivraspaces.com/assets/img/services/3x/service2.jpg">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/favicon_io/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon_io/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/favicon_io/favicon-16x16.png">
  <link rel="manifest" href="/assets/img/favicon_io/site.webmanifest">
  <link href="/assets/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/bootstrap-icons/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/assets/css/common.css">
  <link rel="stylesheet" href="/assets/sweetalert/sweetalert2.css">
</head>
<body>
  <div class="about-outer-wrapper">
    <div class="header-wrapper">
      <div class="header-contactdetails-wrapper">
        <div class="header-contactdetails-textbox">
          <span>Call Now: +91 91331 32333 | Email: sivraspaces.interiors@gmail.com</span>
          <span>Opening time: Sun-Sat 9:00 AM - 7:00 PM</span>
        </div>
      </div>
      <div class="header-navigation-wrapper">
        <div><%- include('../partials/header') %></div>
      </div>
    </div>

    <div class="body-wrapper">
      <main>
        <!-- Breadcrumb -->
        <section id="breadcrumb" class="breadcrumb-section">
          <div class="breadcrumb-wrapper">
            <img src="/assets/img/breadcrumb/services.png" alt="services breadcrumb">
            <div class="breadcrumb-overlay"></div>
            <div class="breadcrumb-text">
              <h2><span style="color: #f45b1e">WARDROBE</span></h2>
              <p>Custom-Built Wardrobes for Every Room</p>
              <div class="breadcrumb-path">
                <span style="color: black">HOME</span>
                <i class="bi bi-dot"></i>
                <a href="/services/interior-design" style="color: black; text-decoration: none;">SERVICES</a>
                <i class="bi bi-dot"></i>
                <span>WARDROBE</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Hero Section -->
        <section class="py-5">
          <div class="container">
            <div class="row align-items-center gy-4">
              <div class="col-md-6">
                <h2 class="fw-bold">
                  <span class="text-uppercase">Wardrobes</span><br>
                  <span class="highlight-word text-uppercase">Built Around Your Space</span>
                </h2>
                <p class="mt-3">
                  Our custom-built wardrobes are crafted to maximize storage while complementing your room's aesthetics. Whether you prefer sliding doors, hinged panels, or a walk-in setup, we design and build to your exact dimensions and taste.
                </p>
                <p>
                  Every wardrobe we build uses premium materials and precision woodwork to ensure smooth operation, durability, and a finish that elevates the entire room.
                </p>
              </div>
              <div class="col-md-6 text-center">
                <img src="/assets/img/services/3x/service2.jpg" alt="Wardrobe" class="img-fluid rounded" style="height: 350px; width: 100%; object-fit: cover;">
              </div>
            </div>
          </div>
        </section>

        <!-- Features Section -->
        <section style="background-color: #132023;" class="py-5">
          <div class="container">
            <div class="text-center mb-5">
              <h2 class="fw-bold text-light">WHAT WE <span class="highlight-word">OFFER</span></h2>
              <p class="text-light">Wardrobes crafted with care to fit your life perfectly.</p>
            </div>
            <div class="row gy-4">
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-door-open" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Sliding Wardrobes</h5>
                  <p class="text-light" style="opacity: 0.8;">Space-saving sliding door wardrobes with smooth tracks, ideal for compact bedrooms.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-layout-sidebar" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Hinged Wardrobes</h5>
                  <p class="text-light" style="opacity: 0.8;">Classic hinged door wardrobes with full interior access and deep storage compartments.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-house-door" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Walk-In Wardrobes</h5>
                  <p class="text-light" style="opacity: 0.8;">Luxury walk-in wardrobe rooms with custom shelving, drawers, and display sections.</p>
                </div>
              </div>
              <div class="col-md-6 col-lg-3">
                <div class="p-4 rounded h-100" style="background-color: #1e3035; border-left: 4px solid #f45b1e;">
                  <i class="bi bi-palette" style="font-size: 2rem; color: #f45b1e;"></i>
                  <h5 class="text-light mt-3">Premium Finishes</h5>
                  <p class="text-light" style="opacity: 0.8;">Choose from a wide range of laminates, veneers, and lacquered finishes for a flawless look.</p>
                </div>
              </div>
            </div>
          </div>
        </section>


        <!-- Footer -->
        <section id="footer" class="footer-wrapper">
          <%- include('../partials/footer') %>
        </section>

        <section id="get-a-quote-sticker" class="get-a-quote-sticker-wrap d-flex flex-column">
          <%- include('../partials/get-quote-sticker') %>
        </section>

        <section>
          <div class="overlay" id="overlay"></div>
          <div id="get-a-quote-dialog" class="get-a-quote-dialog">
            <div style="text-align: right" id="cancel-quote-form">
              <i class="bi bi-x-circle-fill" style="font-size: 40px"></i>
            </div>
            <div><%- include('../partials/get-quote-form') %></div>
          </div>
        </section>
      </main>

      <%- include('../partials/mobile-nav') %>
    </div>
  </div>

  <script src="/assets/JQuery/jquery1.min.js"></script>
  <script src="/assets/JS/mobile-navigation-script.js"></script>
  <script src="/assets/sweetalert/sweetalert2.all.min.js"></script>
  <script src="/assets/JS/get-a-quote-dialog-script.js"></script>
  <script src="/assets/JS/contact-form-submission.js"></script>
</body>
</html>
