  <script>   // code for AOS 
    AOS.init({
      duration: 1000,
      easing: "ease-in-out",
      once: true,
      mirror: false,
    });
  </script>
  <script>
    $(document).ready(function () {
      $(".banner-carousel").owlCarousel({
        loop: true, // Enables infinite looping
        margin: 0,  // No margin between slides
        dots: true,
        items: 1,   // Displays one item at a time
        autoplay: true, // Automatically slides to the next
        autoplayTimeout: 8500, // 5-second interval
        autoplayHoverPause: false, // Pauses autoplay on hover
      });

      $(".testimonial-carousel").owlCarousel({
        loop: true,
        margin: 0,
        dots: true,
        items: 1,
        autoplay: true,
        autoplayTimeout: 3500,
        autoplayHoverPause: false,
      });


    });

  </script>


