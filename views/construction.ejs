<!DOCTYPE html>
<html lang="en">

<head>

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
      content="Transform your spaces with expert interior design solutions! Discover stunning designs, personalized services, and innovative ideas to create the home or office of your dreams">
    <meta name="keywords"
      content="Interior design, Home decor, Office Interiors, Modern interior design, Luxury interiors, Space planning, Interior styling, Personalized design services, Contemporary decor, Interior design trends">
    <title>Services - Sivra Spaces</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/favicon_io/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon_io/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/favicon_io/favicon-16x16.png">
    <link rel="manifest" href="/assets/img/favicon_io/site.webmanifest">
    <link rel="stylesheet" href="/assets/owl-carousel/owl1.carousel.min.css" />
    <link rel="stylesheet" href="/assets/owl-carousel/owl1.theme.default.min.css" />
    <link href='https://fonts.googleapis.com/css?family=Orbitron' rel='stylesheet'>
    <link href="/assets/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/bootstrap-icons/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/assets/aos/aos.css">
    <link rel="stylesheet" href="/assets/css/common.css">
    <link rel="stylesheet" href="/assets/sweetalert/sweetalert2.css">
  
    <!-- <link rel="stylesheet" href="/assets/css/about.css"> -->
  </head>
</head>

<body>
  <div class="about-outer-wrapper">
    <div class="header-wrapper">
      <div class="header-contactdetails-wrapper">
        <div class="header-contactdetails-textbox">
          <span>Call Now: +91 91331 32333,  | Email: sivraspaces.interiors@gmail.com
          </span>
          <span>Opening time: Sun-Sat 9:00 AM - 7:00 PM
          </span>
        </div>
      </div>
      <div class="header-navigation-wrapper">
        <div>
          <%- include('./partials/header') %>
        </div>
      </div>
    </div>
    <div class="body-wrapper">
      <main>
        <section id="breadcrumb" class="breadcrumb-section">
          <div class="breadcrumb-wrapper">
            <img src="/assets/img/breadcrumb/services.png" alt="services breadcrumb image">
            <div class="breadcrumb-overlay"></div>
            <div class="breadcrumb-text">
              <h2><span style="color: #F45B1E;">SERVICES</span></h2>
              <p>Expert Construction Solutions for Your Dream Projects</p>
              <div class="breadcrumb-path">
                <span style="color: black;">HOME</span> <i class="bi bi-dot"></i> <span>CONSTRUCTION</span>
              </div>
            </div>
          </div>
         
        </section>
        <section>
            <div class="container my-5">
                <div class="row align-items-center">
                  <!-- Text Section -->
                  <div class="col-md-6">
                    <h3 class="fw-bold">
                      <span class="text-uppercase">Dependable</span> 
                      <span class="text-uppercase highlight-word"  >Construction Solutions</span>
                    </h3>
                    <p class="mt-3">
                        ATL Interior and Construction provides an integrated, client-focused approach tailored to your unique needs. We offer transparent operational advantages through a streamlined contract with a single entity, enabling us to fast-track projects efficiently.
                    </p>
                    <p>
                        At ATL Interior and Construction, we are dedicated to turning your vision—whether it's a dream home, a commercial property, or a farmhouse—into reality. Our extensive team brings leadership and momentum to deliver complete turnkey solutions, always with professionalism, integrity, and unwavering commitment to every project.
                    </p>
                  </div>
                  <!-- Image Section -->
                  <div class="col-md-6 text-center">
                 
                      <img src="/assets/img/services/construction/construction.png" alt="construction Image" class="img-fluid  rounded" >
                   
                  </div>
                </div>
              </div>
              
        </section>
        <section style="background-color: #132023;" class="py-4">
            <div class="container my-5">
                <!-- Heading Section -->
                <div class="text-center mb-4">
                  <h2 class="fw-bold"><span class="text-light">WE PROVIDE EXCELLENT</span><br> <span class="highlight-word">SERVICE TO OUR CUSTOMERS</span></h2>
                  <p class="text-light">
                    The art and science of enhancing the interior of a building to create a healthier, more aesthetically pleasing environment for the people using the space.
                  </p>
                </div>
              
                <!-- Cards Section -->
                <div class="row gy-4">
                  <!-- Residential Design -->
                  <div class="col-md-4">
                    <div class="card shadow text-light h-100" style="background-color: #132023;">
                      <img src="/assets/img/services/construction/construction1.png" class="card-img-top" alt="Residential Design">
                      <div class="card-body">
                        <h5 class="card-title highlight-word">Residential construction</h5>
                        <p class="card-text">
                          Residential construction refers to the process of building homes or residential buildings, including single-family homes, townhouses, condominiums, and apartment complexes. This field covers everything from the planning and design phase to the actual construction, finishing, and handover of a completed structure.
                        </p>
                      </div>
                    </div>
                  </div>
                  <!-- Commercial Design -->
                  <div class="col-md-4">
                    <div class="card shadow text-light h-100" style="background-color: #132023;">
                      <img src="/assets/img/services/construction/construction2.png" class="card-img-top" alt="Commercial Design">
                      <div class="card-body">
                        <h5 class="card-title highlight-word">Villa buildings</h5>
                        <p class="card-text">
                          Villa buildings refer to luxurious, often larger single-family homes that are designed with comfort, privacy, and high-end living in mind. Villas typically feature spacious layouts, elegant architectural details, and upscale finishes. They are commonly found in affluent residential areas, vacation destinations, or as part of high-end resorts.
                        </p>
                      </div>
                    </div>
                  </div>
                  <!-- Architectural Design -->
                  <div class="col-md-4">
                    <div class="card shadow text-light h-100" style="background-color: #132023;">
                      <img src="/assets/img/services/construction/construction3.png" class="card-img-top" alt="Architectural Design">
                      <div class="card-body">
                        <h5 class="card-title highlight-word">Farm House</h5>
                        <p class="card-text">
                          Farmhouse construction typically refers to building homes designed for agricultural purposes or rural living, though in modern contexts, it often refers to residential homes that evoke a rustic, country-style aesthetic. Farmhouses traditionally served as the main residence on a farm, housing the farmer and their family.
                        </p>
                      </div>
                    </div>
                  </div>
                  <!-- Hospitality Design -->
                  <div class="col-md-4">
                    <div class="card shadow text-light h-100" style="background-color: #132023;">
                      <img src="/assets/img/services/construction/construction4.png" class="card-img-top" alt="Hospitality Design">
                      <div class="card-body">
                        <h5 class="card-title highlight-word">Commercial building</h5>
                        <p class="card-text">
                          Commercial building construction involves the design and development of structures that are intended for business, retail, office, industrial, or institutional use. These buildings are typically designed to generate revenue, house businesses, or serve as public or private facilities.
                        </p>
                      </div>
                    </div>
                  </div>
                  <!-- Restaurant Design -->
                  <div class="col-md-4">
                    <div class="card shadow text-light h-100" style="background-color: #132023;">
                      <img src="/assets/img/services/construction/construction5.png" class="card-img-top" alt="Restaurant Design">
                      <div class="card-body">
                        <h5 class="card-title highlight-word">Turnkey projects</h5>
                        <p class="card-text">
                          In a turnkey project, the contractor or service provider handles the entire process from start to finish, including all planning, design, construction, installation, and sometimes even ongoing maintenance or operational management. The result is a fully functional product or facility.
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              
        </section>
        <!-- gallery -->
         <section>
            <div class="container py-5">
                <h3>GALLERY</h3>
                <div class="row">
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery1.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery2.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery3.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery4.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery5.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery6.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery7.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery8.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery9.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery10.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery11.png" alt="interior service gallery" class="img-fluid">
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mt-3">
                        <img src="/assets/img/services/construction/constructiongallery12.png" alt="interior service gallery" class="img-fluid">
                    </div>
                </div>
            </div>
         </section>
        <!-- footer -->
        <section id="footer" class="footer-wrapper">
          <%- include('./partials/footer') %>
        </section>

        <section id="get-a-quote-sticker" class="get-a-quote-sticker-wrap d-flex flex-column">
          <%- include('./partials/get-quote-sticker') %>
        </section>

        <section>
          <div class="overlay" id="overlay"></div>
          <div id="get-a-quote-dialog" class="get-a-quote-dialog">
            <div style="text-align: right;" id="cancel-quote-form">
              <i class="bi bi-x-circle-fill" style="font-size: 40px;"></i>
            </div>
            <div>
              <%- include('./partials/get-quote-form') %>
            </div>
          </div>
        </section>

      </main>
      <%- include('./partials/mobile-nav') %>
    </div>
  </div>
  <script src="/assets/JQuery/jquery1.min.js"></script>
  <script src="/assets/owl-carousel/owl1.carousel.min.js"></script>
  <script src="/assets/JS/mobile-navigation-script.js"></script>
  <script src="/assets/sweetalert/sweetalert2.all.min.js"></script>
  <script src="/assets/JS/get-a-quote-dialog-script.js"></script>
  <script src="/assets/JS/contact-form-submission.js"></script>
  <script>
    function playVideo() {
      const iframe = document.querySelector('iframe');
      const cover = document.querySelector('.cover');
      iframe.style.display = 'block'; // Show the video
      cover.style.display = 'none'; // Hide the cover
    }
  </script>

  <script>
    $(document).ready(function () {
      $(".testimonial-carousel").owlCarousel({
        loop: true,
        margin: 0,
        dots: true,
        items: 1,
        autoplay: true,
        autoplayTimeout: 3500,
        autoplayHoverPause: false,
      });
    });

  </script>
</body>

</html>